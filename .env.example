# --- Backend ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me

# --- Database ---
DATABASE_URL=postgresql+psycopg://buraki:buraki@localhost:5432/buraki
# Docker ağı içinden API'nin kullanacağı bağlantı (host adı: postgres)
API_DATABASE_URL=postgresql+psycopg://buraki:buraki@postgres:5432/buraki
DATA_REPOSITORY=auto
POSTGRES_USER=buraki
POSTGRES_PASSWORD=buraki
POSTGRES_DB=buraki

# --- Redis / Cache ---
REDIS_URL=redis://localhost:6379/0

# --- Auth (OIDC/JWT) ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MIN=30

# --- ML ---
MODEL_REGISTRY_DIR=./data/models
GES_MODEL_FILE=Yapay_Zeka_GES_Modeli.json
RES_MODEL_FILE=Yapay_Zeka_RES_Modeli.json
SCORING_CONFIG_PATH=./ml/scoring/scoring_config.json

# --- Object Storage (S3 uyumlu) ---
S3_ENDPOINT=
S3_BUCKET=buraki-artifacts
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
